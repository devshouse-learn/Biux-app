# ============================================
# FASTLANE CONFIGURATION - BIUX
# Autenticación con API Tokens (Seguro)
# ============================================

# Método 1: API Token (RECOMENDADO)
# Descargar de: https://appstoreconnect.apple.com/access/api
APP_STORE_CONNECT_KEY_ID=ABC123DEF45
APP_STORE_CONNECT_ISSUER_ID=12345678-1234-1234-1234-123456789012
# AuthKey.p8 debe estar en ios/fastlane/AuthKey.p8

# Método 2: App-Specific Password (opcional, fallback)
# De: https://appleid.apple.com/account/manage
FASTLANE_USER=tu_email@apple.com
FASTLANE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Team Configuration
TEAM_ID=XXXXXXXXXX
TEAM_NAME="Tu Team Name"

# App Configuration
APP_IDENTIFIER=org.devshouse.biux
APP_NAME=BIUX

# TestFlight Configuration
TESTFLIGHT_BETA_FEEDBACK_EMAIL=beta@devshouse.com
TESTFLIGHT_GROUPS="Internal Testers"

# Build Configuration
CONFIGURATION=Release
SCHEME=Runner
WORKSPACE=Runner.xcworkspace
XCODEPROJ=Runner.xcodeproj

# Provisioning
PROVISIONING_PROFILE_IDENTIFIER=match\ AppStore\ org.devshouse.biux
CODE_SIGN_IDENTITY=iPhone Distribution

# Logging
FASTLANE_HIDE_CHANGELOG=true
FASTLANE_SKIP_UPDATE_CHECK=true

# ============================================
# INSTRUCCIONES
# ============================================
# 1. Copiar a: ios/fastlane/.env.local
# 2. Rellenar con tus datos reales
# 3. NO subir a Git (.env.local está en .gitignore)
# 4. Para API Token: descargar AuthKey.p8 de Apple Developer

