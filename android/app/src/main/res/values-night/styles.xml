<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema para la pantalla de splash en modo nocturno -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <!-- Color de la barra de estado -->
        <item name="android:statusBarColor">@color/biux_background_dark</item>
        <!-- Color de la barra de navegación -->
        <item name="android:navigationBarColor">@color/biux_background_dark</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <!-- Tema normal en modo nocturno -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/biux_background_dark</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <!-- Color de la barra de estado en modo oscuro -->
        <item name="android:statusBarColor">@color/biux_background_dark</item>
        <!-- Color de la barra de navegación -->
        <item name="android:navigationBarColor">@color/biux_background_dark</item>
    </style>
</resources>
