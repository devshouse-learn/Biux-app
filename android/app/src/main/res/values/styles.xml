<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema para la pantalla de splash (Launch) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Mostrar imagen de splash personalizada -->
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Ocultar la barra de título -->
        <item name="android:windowNoTitle">true</item>
        <!-- Pantalla completa -->
        <item name="android:windowFullscreen">true</item>
        <!-- Evitar redimensionado por teclado -->
        <item name="android:windowSoftInputMode">adjustResize</item>
        <!-- Color de la barra de estado -->
        <item name="android:statusBarColor">@color/biux_primary</item>
        <!-- Color de la barra de navegación -->
        <item name="android:navigationBarColor">@color/biux_primary</item>
    </style>

    <!-- Tema normal de la aplicación -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/biux_background_light</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <!-- Color de la barra de estado en modo claro -->
        <item name="android:statusBarColor">@color/biux_primary</item>
        <!-- Color de la barra de navegación -->
        <item name="android:navigationBarColor">@color/biux_background_light</item>
    </style>
</resources>